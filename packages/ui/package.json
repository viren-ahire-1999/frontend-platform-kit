{
  "name": "@fpk/ui",
  "version": "0.0.0",
  "private": true,
  "description": "FPK shared UI component library (design system). Consumed by the shell and all remotes.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006 --no-open",
    "build": "tsup",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rimraf dist .turbo storybook-static *.tsbuildinfo"
  },
  "peerDependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@fpk/eslint-config": "workspace:*",
    "@fpk/tsconfig": "workspace:*",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.9.0",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "storybook": "^10.4.6",
    "tsup": "^8.5.1",
    "typescript": "^5.5.4",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
