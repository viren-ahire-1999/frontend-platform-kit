{
  "name": "@fpk/utils",
  "version": "0.0.0",
  "private": true,
  "description": "FPK shared framework-agnostic utilities (formatters, helpers).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "@fpk/eslint-config": "workspace:*",
    "@fpk/tsconfig": "workspace:*",
    "eslint": "^9.9.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.5.4"
  }
}
