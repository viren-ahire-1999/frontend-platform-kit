# Always resolve from the public npm registry so installs are reproducible
# anywhere (CI, Cloudflare, fresh clones), independent of local registry config.
registry=https://registry.npmjs.org/
# Keep node_modules clean: only declared dependencies are importable.
shamefully-hoist=false
# Auto-install peer deps so MFEs share a single React/ReactDOM resolution.
auto-install-peers=true
strict-peer-dependencies=false
# Allow tooling (e.g. cloudflare/wrangler-action) to install CLI deps at the
# workspace root in CI instead of failing with ERR_PNPM_ADDING_TO_ROOT.
ignore-workspace-root-check=true
# Hoist React to the top so every micro-frontend resolves the same instance.
# This is critical for Module Federation shared singletons.
public-hoist-pattern[]=*react*
public-hoist-pattern[]=*react-dom*
